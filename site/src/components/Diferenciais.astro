---
// Seção "Ferramentas & diferenciais" (sem título), abaixo de Trabalhos. Tags simples. Consome perfil.ts.
import { perfil } from '../data/perfil.ts';
const { ferramentas, diferenciais } = perfil;
---
<section id="ferramentas" class="section">
  <div class="container">
    <div class="fd-grid">
      <div class="fd-block">
        <p class="fd-label">Minhas ferramentas · Top 5</p>
        <div class="fd-tags">{ferramentas.map((t) => (<span>{t}</span>))}</div>
      </div>
      <div class="fd-block">
        <p class="fd-label">Meus diferenciais</p>
        <div class="fd-tags">{diferenciais.map((t) => (<span>{t}</span>))}</div>
      </div>
    </div>
  </div>
</section>

<style>
  #ferramentas { scroll-margin-top: 84px; }
  .fd-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 40px; align-items: start; }
  .fd-label { font-family: var(--fm); font-size: 14px; text-transform: uppercase; letter-spacing: .08em; color: var(--ts); margin: 0 0 14px; display: flex; align-items: center; gap: 9px; }
  .fd-label::before { content: ''; width: 12px; height: 3px; border-radius: 2px; background: var(--int); flex-shrink: 0; }
  .fd-tags { display: flex; flex-wrap: wrap; gap: 10px; }
  .fd-tags span { font-size: 14px; color: var(--tp); background: var(--surface-alt); border: .5px solid var(--bd); border-radius: 999px; padding: 8px 15px; line-height: 1.3; }
  @media (max-width: 768px) { .fd-grid { grid-template-columns: 1fr; gap: 28px; } }
</style>
