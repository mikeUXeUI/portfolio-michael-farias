---
// Layout base: shell HTML, tokens, tema (light/dark persistido antes do paint),
// View Transitions (header persistente), toast global + utilitários de cópia.
// Componentes (Nav, Hero, Trabalho, Sobre, Footer) entram nas páginas.
import '../styles/tokens.css';
export interface Props { title?: string; description?: string; }
const {
  title = 'Michael Farias · Product Designer',
  description = 'Portfólio de Michael Farias, Product Designer SaaS/B2B, dados e IA.'
} = Astro.props;
// URLs absolutas derivadas de `site` no astro.config (fonte única do domínio).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('og.png', Astro.site).href;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Open Graph / compartilhamento (thumb ao colar o link) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- aplica o tema antes do paint pra evitar flash -->
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('theme');
          var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', s || (d ? 'dark' : 'light'));
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- toast global (copiar e-mail) -->
    <div class="toast" id="toast" role="status" aria-live="polite"></div>
    <script is:inline>
      /* util global: copiar texto + toast (reusado por modal e footer) */
      window.__toastT = null;
      window.showToast = function (msg) {
        var t = document.getElementById('toast'); if (!t) return;
        t.textContent = msg; t.classList.add('show');
        clearTimeout(window.__toastT);
        window.__toastT = setTimeout(function () { t.classList.remove('show'); }, 2200);
      };
      window.copyText = function (txt) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          return navigator.clipboard.writeText(txt);
        }
        return new Promise(function (res, rej) {
          try {
            var ta = document.createElement('textarea');
            ta.value = txt; ta.style.position = 'fixed'; ta.style.opacity = '0';
            document.body.appendChild(ta); ta.select();
            document.execCommand('copy'); document.body.removeChild(ta); res();
          } catch (e) { rej(e); }
        });
      };
    </script>
  </body>
</html>

<style is:global>
  @view-transition { navigation: auto; }
  *, *::before, *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; scrollbar-gutter: stable; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    transition: background .2s, color .2s;
  }
  h1, h2, h3 { margin: 0; line-height: 1.2; font-weight: 500; }
  a { color: inherit; }
  .mono { font-family: var(--font-mono); }
  .container {
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
  }
  .section { padding-block: 64px; border-top: .5px solid var(--bd); }
  .shead { font-size: 14px; letter-spacing: .08em; text-transform: uppercase; color: var(--ts); margin: 0 0 24px; display: flex; align-items: center; gap: 9px; }
  .shead::before { content: ''; width: 12px; height: 3px; border-radius: 2px; background: var(--int); flex-shrink: 0; }
  .shead-link { color: inherit; text-decoration: none; display: inline-block; transition: color .15s ease; }
  .shead-link:hover { color: var(--int); }

  .toast {
    position: fixed; left: 50%; bottom: 28px;
    transform: translateX(-50%) translateY(12px); z-index: 70;
    background: var(--tp); color: var(--bg);
    font-size: 14px; letter-spacing: .01em; padding: 10px 16px; border-radius: 10px;
    box-shadow: 0 8px 24px rgba(20,30,50,.18);
    opacity: 0; pointer-events: none;
    transition: opacity .2s ease, transform .3s cubic-bezier(.2,.7,.2,1); text-transform: none;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  @media (prefers-reduced-motion: reduce) { .toast { transition: opacity .2s ease; } }

  @media (prefers-reduced-motion: reduce) {
    body,
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) { animation: none !important; }
  }
</style>
